# BODS API key — obtain from https://data.bus-data.dft.gov.uk/ (Account Settings)
BODS_API_KEY=

# Flask server configuration
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# CORS — comma-separated origins, or * for development only
ALLOWED_ORIGINS=*

# Cache settings
CACHE_TIMEOUT=15
CACHE_MAX_SIZE=256
